<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel Admin - Gestión Usuarios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4 shadow">
        <div class="container">
            <span class="navbar-brand"><i class="bi bi-shield-lock"></i> SISTEMA VACACIONES | ADMIN</span>
            <a href="/logout" class="btn btn-outline-danger btn-sm">Cerrar Sesión</a>
        </div>
    </nav>

    <div class="container">
        <!-- CREAR NUEVO USUARIO -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-white text-primary"><strong><i class="bi bi-person-plus"></i> Crear Nuevo Usuario</strong></div>
            <div class="card-body">
                <form action="/admin/users" method="POST" class="row g-2">
                    <div class="col-md-3">
                        <input type="text" name="username" class="form-control" placeholder="Nombre de usuario" required>
                    </div>
                    <div class="col-md-3">
                        <input type="email" name="email" class="form-control" placeholder="Correo electrónico" required>
                    </div>
                    <div class="col-md-2">
                        <input type="password" name="password" class="form-control" placeholder="Contraseña Temporal" required>
                    </div>
                    <div class="col-md-2">
                        <select name="role" class="form-select">
                            <option value="Admin">Admin</option>
                            <option value="RRHH">RRHH</option>
                            <option value="Supervisor">Supervisor</option>
                            <option value="Nominas">Nóminas</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-success w-100"><i class="bi bi-plus-lg"></i> Crear</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- LISTA DE USUARIOS -->
        <div class="card shadow-sm">
            <div class="card-header bg-white"><strong><i class="bi bi-people"></i> Usuarios del Sistema</strong></div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Usuario</th><th>Email</th><th>Rol</th><th>Estado Contraseña</th><th>Acción</th></tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                        <tr>
                            <td><strong><%= user.username %></strong></td>
                            <td><%= user.email %></td>
                            <td><span class="badge bg-secondary"><%= user.role %></span></td>
                            <td>
                                <% if(user.mustChangePassword) { %>
                                    <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Pendiente de Cambio</span>
                                <% } else { %>
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Actualizada</span>
                                <% } %>
                            </td>
                            <td>
                                <!-- BOTÓN RESET CON MENSAJE DE CONFIRMACIÓN -->
                                <form action="/admin/reset-password/<%= user.id %>" method="POST">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" 
                                        onclick="return confirm('Se restablecerá la contraseña del usuario <%= user.username %> a:\n\n123456\n\nEl sistema le pedirá cambiarla al iniciar sesión. ¿Estás seguro?')">
                                        <i class="bi bi-arrow-counterclockwise"></i> Reset Pwd
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>
